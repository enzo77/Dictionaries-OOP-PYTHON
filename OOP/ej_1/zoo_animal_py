class Animal:
    """
    Representa un animal con especie, nombre y edad.

    Attributes:
        species (str): Especie del animal.
        name (str): Nombre del animal.
        age (int): Edad del animal en años.
    """

    def __init__(self,species, name, age):
        """
        Inicializa una nueva instancia de Animal.

        Args:
            species (str): Especie del animal.
            name (str): Nombre del animal.
            age (int): Edad del animal en años.
        """
        self.species = species
        self.name = name
        self.age = age
        
    def info(self):
        """
        Devuelve una descripción del animal.

        Returns:
            str: Cadena con el nombre, especie y edad del animal.
        """
        return f"{self.name} is a {self.age}-year-old {self.species}"
        
a = Animal("Lion", "Simba", 5)
print(a.info())